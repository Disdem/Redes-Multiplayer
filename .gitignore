*.pidb.meta
*.pdb.meta
*.mdb.meta

# Archivo generado por Unity3D en reportes de crasheo
sysinfo.txt

# ==============================================================================
# COMPILACIONES (BUILDS)
# ==============================================================================
*.apk
*.aab
*.unitypackage
*.app

# Archivo generado por Crashlytics
crashlytics-build.properties

