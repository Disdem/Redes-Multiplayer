# ==============================================================================
# ARCHIVOS DE IDEs Y CÓDIGO (Visual Studio, Rider, etc.)
# ==============================================================================
# Caché de Visual Studio y Gradle
.vs/
.gradle/

# Archivos de solución y proyectos autogenerados (VS/MD/Consulo)
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
